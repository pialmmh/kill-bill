<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<overdueConfig>
    <accountOverdueStates>
        <!--
            State flow for unpaid invoices:
            GOOD -> WARNING (7 days) -> SUSPENDED (14 days) -> DISCONNECTED (30 days)

            When paid at any stage -> auto-clears back to GOOD
        -->

        <!-- After 30 days unpaid: disconnect service -->
        <state name="DISCONNECTED">
            <condition>
                <timeSinceEarliestUnpaidInvoiceEqualsOrExceeds>
                    <unit>DAYS</unit>
                    <number>30</number>
                </timeSinceEarliestUnpaidInvoiceEqualsOrExceeds>
            </condition>
            <externalMessage>Account disconnected due to non-payment. Please contact support.</externalMessage>
            <blockChanges>true</blockChanges>
            <disableEntitlement>true</disableEntitlement>
            <isClearState>false</isClearState>
            <autoReevaluationInterval>
                <unit>DAYS</unit>
                <number>7</number>
            </autoReevaluationInterval>
        </state>

        <!-- After 14 days unpaid: suspend service (block line) -->
        <state name="SUSPENDED">
            <condition>
                <timeSinceEarliestUnpaidInvoiceEqualsOrExceeds>
                    <unit>DAYS</unit>
                    <number>14</number>
                </timeSinceEarliestUnpaidInvoiceEqualsOrExceeds>
            </condition>
            <externalMessage>Service suspended due to overdue payment. Pay now to restore.</externalMessage>
            <blockChanges>true</blockChanges>
            <disableEntitlement>true</disableEntitlement>
            <isClearState>false</isClearState>
            <autoReevaluationInterval>
                <unit>DAYS</unit>
                <number>5</number>
            </autoReevaluationInterval>
        </state>

        <!-- After 7 days unpaid: warning -->
        <state name="WARNING">
            <condition>
                <timeSinceEarliestUnpaidInvoiceEqualsOrExceeds>
                    <unit>DAYS</unit>
                    <number>7</number>
                </timeSinceEarliestUnpaidInvoiceEqualsOrExceeds>
            </condition>
            <externalMessage>Payment overdue. Please pay within 7 days to avoid service suspension.</externalMessage>
            <blockChanges>false</blockChanges>
            <disableEntitlement>false</disableEntitlement>
            <isClearState>false</isClearState>
            <autoReevaluationInterval>
                <unit>DAYS</unit>
                <number>3</number>
            </autoReevaluationInterval>
        </state>
    </accountOverdueStates>
</overdueConfig>
